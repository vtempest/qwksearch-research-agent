{
  "name": "qwksearch-web",
  "description": "Search, extract, vectorize, outline graph, and monitor the web for topic keywords",
  "version": "2.2.0",
  "author": "vtempest",
  "license": "rights.institute/prosper",
  "scripts": {
    "dev": "rm -rf .next; open-ready next dev  --turbo",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "opennextjs-cloudflare start",
    "dev:cf": "npx wrangler dev --local",
    "preview": "NODE_OPTIONS='--max-old-space-size=4096' opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:staging": "NODE_OPTIONS='--max-old-space-size=4096' opennextjs-cloudflare build && opennextjs-cloudflare deploy --env staging",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:d1": "drizzle-kit push --config drizzle.d1.config.ts",
    "db:migrate:d1": "for f in drizzle/*.sql; do echo ''; wrangler d1 execute qwksearch --remote --file=$f; done",
    "db:studio": "drizzle-kit studio",
    "db:create": "bun x create cloud-db",
    "analyze": "ANALYZE=true next build --webpack",
    "favicon": "bun create favicon public/favicon-512.png public/ --overwrite"
  },
