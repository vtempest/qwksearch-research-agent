{
  "name": "qwksearch-api",
  "description": "Search, extract, vectorize, outline graph, and monitor the web for topic keywords",
  "version": "2.2.0",
  "author": "vtempest",
  "license": "rights.institute/prosper",
  "scripts": {
    "dev": "rm -rf .next; next dev --turbo",
    "dev:cf": "npx wrangler dev --local",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "opennextjs-cloudflare start",
    "preview": "NODE_OPTIONS='--max-old-space-size=4096' opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:staging": "NODE_OPTIONS='--max-old-space-size=4096' opennextjs-cloudflare build && opennextjs-cloudflare deploy --env staging",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:create": "bun x create cloud-db"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.5",
    "@langchain/core": "^1.1.29",
    "@langchain/groq": "^1.1.3",
    "better-auth": "^1.5.1",
    "better-auth-cloudflare": "^0.2.9",
    "drizzle-orm": "^0.45.1",
    "grab-url": "^1.5.6",
    "manage-storage": "^0.0.5",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.0",
    "@opennextjs/cloudflare": "^1.19.5",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "latest"
  }
}
